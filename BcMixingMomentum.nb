Notebook[{
  Cell["B_c Mixing Angle: Momentum-Space QCD Sum Rule", "Title"],
  Cell["This notebook is a thin wrapper around BcMixingMomentum.wl. Evaluate the cells from top to bottom in a Wolfram kernel where FeynCalc is installed.", "Text"],

  Cell["Load", "Section"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"SetDirectory", "[", RowBox[{"NotebookDirectory", "[", "]"}], "]"}],
      ";"
    }]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"Get", "[", "\"BcMixingMomentum.wl\"", "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"CheckEnvironment", "[", "]"}]
  ], "Input"],

  Cell["Mass-Dimension Checks", "Section"],
  Cell["The tensor current is normalized with p/(mb+mc), so AA, AB, BA, and BB have compatible spectral-density dimensions. The False case shows the deliberately unnormalized convention.", "Text"],
  Cell[BoxData[
    RowBox[{"MixingMassDimensionReport", "[", "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"CheckMixingMassDimensions", "[", "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"PerturbativeSpectralDensityDimensionReport", "[", "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"MixingMassDimensionReport", "[", "False", "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"CheckMixingMassDimensions", "[", "False", "]"}]
  ], "Input"],

  Cell["Projected Loop Integrands", "Section"],
  Cell["These cells build the spin-1 projected OPE-side integrands before the final spectral-density step.", "Text"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"Correlator", "[", RowBox[{"\"AA\"", ",", "\"pert\""}], "]"}],
      "//",
      "Short"
    }]
  ], "Input"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"Correlator", "[", RowBox[{"\"AB\"", ",", "\"pert\""}], "]"}],
      "//",
      "Short"
    }]
  ], "Input"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"Correlator", "[", RowBox[{"\"BB\"", ",", "\"pert\""}], "]"}],
      "//",
      "Short"
    }]
  ], "Input"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"Correlator", "[", RowBox[{"\"AA\"", ",", "\"G2\""}], "]"}],
      "//",
      "Short"
    }]
  ], "Input"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"Correlator", "[", RowBox[{"\"AA\"", ",", "\"G3\""}], "]"}],
      "//",
      "Short"
    }]
  ], "Input"],

  Cell["Feynman-Parameter Representation", "Section"],
  Cell["Use these expressions to derive or check rho[channel, order][s]. The output is a list of {parameterIntegrand, prefactor, variables}, one item per scalar loop-integral term.", "Text"],
  Cell[BoxData[
    RowBox[{"FeynmanParameterForm", "[", RowBox[{"\"AA\"", ",", "\"pert\""}], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"FeynmanParameterForm", "[", RowBox[{"\"AB\"", ",", "\"pert\""}], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"FeynmanParameterForm", "[", RowBox[{"\"BB\"", ",", "\"pert\""}], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"FeynmanParameterForm", "[", RowBox[{"\"AA\"", ",", "\"G2\""}], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"FeynmanParameterForm", "[", RowBox[{"\"AA\"", ",", "\"G3\""}], "]"}]
  ], "Input"],

  Cell["Borel Moments And Mixing Angle", "Section"],
  Cell["BorelPi is formal until spectral densities are supplied with SetSpectralDensity[channel, order, expr, s].", "Text"],
  Cell[BoxData[
    RowBox[{"BorelPi", "[", RowBox[{"\"AA\"", ",", "\"pert\""}], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"MixingAngle", "[", RowBox[{"M2", ",", "s0"}], "]"}]
  ], "Input"],
  Cell["The line above is formal unless every requested rho is installed. For numerical work, use the Numeric* functions. Perturbative rho is installed automatically; G2 and the standard single-line G3 term are evaluated as direct Borel moments.", "Text"],
  Cell[BoxData[
    RowBox[{"NumericMixingAngleDegrees", "[", RowBox[{"10", ",", "55", ",", "\"pert\""}], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"NumericMixingAngleDegrees", "[", RowBox[{"10", ",", "55", ",", "\"pertG2\""}], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"NumericMixingAngleDegrees", "[", RowBox[{"10", ",", "55", ",", "\"total\""}], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"NumericOPESummary", "[", RowBox[{"10", ",", "55"}], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"OPESummary", "[", RowBox[{"M2", ",", "s0"}], "]"}]
  ], "Input"],

  Cell["Borel Window And s0 Scans", "Section"],
  Cell["Use {min,max,step} specifications to scan trial Borel windows and continuum thresholds.", "Text"],
  Cell[BoxData[
    RowBox[{"MixingAngleDataset", "[", RowBox[
      {
        RowBox[{"{", RowBox[{"8", ",", "12", ",", "1"}], "}"}],
        ",",
        RowBox[{"{", RowBox[{"50", ",", "60", ",", "5"}], "}"}],
        ",",
        "\"total\""
      }], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"MixingAngleTable", "[", RowBox[
      {
        RowBox[{"{", RowBox[{"8", ",", "12", ",", "1"}], "}"}],
        ",",
        RowBox[{"{", RowBox[{"50", ",", "60", ",", "5"}], "}"}],
        ",",
        "\"total\""
      }], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"OPEConvergenceDataset", "[", RowBox[
      {
        RowBox[{"{", RowBox[{"8", ",", "12", ",", "1"}], "}"}],
        ",",
        RowBox[{"{", RowBox[{"50", ",", "60", ",", "5"}], "}"}]
      }], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"PlotMixingAngle", "[", RowBox[
      {
        RowBox[{"{", RowBox[{"8", ",", "12"}], "}"}],
        ",",
        "55",
        ",",
        "$BcMixingDefaultParameters",
        ",",
        "\"total\""
      }], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"PlotMixingAngleS0", "[", RowBox[
      {
        "10",
        ",",
        RowBox[{"{", RowBox[{"50", ",", "60"}], "}"}],
        ",",
        "$BcMixingDefaultParameters",
        ",",
        "\"total\""
      }], "]"}]
  ], "Input"],
  Cell[BoxData[
    RowBox[{"MixingAngleContourPlot", "[", RowBox[
      {
        RowBox[{"{", RowBox[{"8", ",", "12"}], "}"}],
        ",",
        RowBox[{"{", RowBox[{"50", ",", "60"}], "}"}],
        ",",
        "$BcMixingDefaultParameters",
        ",",
        "\"total\""
      }], "]"}]
  ], "Input"],

  Cell["Optional Manual Override", "Section"],
  Cell["The current workflow installs perturbative rho automatically and evaluates G2/G3 as direct Borel moments. Use SetSpectralDensity only if you want to override a built-in perturbative spectral density for an independent cross-check.", "Text"],
  Cell[BoxData[
    RowBox[{
      RowBox[{"(*",
        RowBox[{
          RowBox[{"SetSpectralDensity", "[", RowBox[{"\"AA\"", ",", "\"pert\"", ",", RowBox[{"rhoAApertIndependent", "[", "s", "]"}], ",", "s"}], "]"}],
          ";"
        }],
      "*)"}]
    }]
  ], "Input"],

  Cell["G3 Caveat", "Section"],
  Cell["The implemented G3 term is the standard vacuum-averaged single-line contribution S_c^(G3) S_b^0 + S_c^0 S_b^(G3). Cross-line open-field G3 terms require a separate derivation and are not guessed in this file.", "Text"]
}]
